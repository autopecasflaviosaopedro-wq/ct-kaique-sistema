import streamlit as st
import sqlite3
import pandas as pd

st.set_page_config(page_title="Cadastro de Modalidades - CT Kaique", layout="wide")

def conectar():
    return sqlite3.connect('gestao_academia.db', check_same_thread=False)

def criar_tabela_grade():
    conn = conectar()
    cursor = conn.cursor()
    cursor.execute('''CREATE TABLE IF NOT EXISTS grade_horarios (
                        id INTEGER PRIMARY KEY AUTOINCREMENT,
                        modalidade TEXT,
                        valor REAL,
                        cronograma TEXT)''')
    conn.commit()
    conn.close()

criar_tabela_grade()

st.title("🥋 Cadastro de Modalidades e Preços")
st.write("---")

with st.expander("➕ Adicionar Nova Modalidade"):
    with st.form("form_modalidade"):
        mod = st.text_input("Nome da Modalidade (Ex: JIU-JITSU, MUAY THAI)").upper()
        valor = st.number_input("Valor da Mensalidade (R$)", min_value=0.0, step=10.0)
        
        st.write("**Defina o Cronograma (Dias e Horários):**")
        dias = ["SEG", "TER", "QUA", "QUI", "SEX", "SAB", "DOM"]
        horarios_dict = {}
        
        for d in dias:
            col1, col2, col3, col4 = st.columns([1, 2, 2, 2])
            with col1: selecionado = st.checkbox(d)
            with col2: m = st.text_input(f"Manhã ({d})", "---")
            with col3: t = st.text_input(f"Tarde ({d})", "---")
            with col4: n = st.text_input(f"Noite ({d})", "---")
            if selecionado:
                horarios_dict[d] = f"M:{m} | T:{t} | N:{n}"

        btn = st.form_submit_button("Salvar Modalidade")
        if btn and mod:
            crono = " / ".join([f"{k}[{v}]" for k, v in horarios_dict.items()])
            conn = conectar()
            cursor = conn.cursor()
            cursor.execute("INSERT INTO grade_horarios (modalidade, valor, cronograma) VALUES (?, ?, ?)", (mod, valor, crono))
            conn.commit()
            conn.close()
            st.success(f"Modalidade {mod} cadastrada!")
            st.rerun()

st.subheader("📋 Modalidades Cadastradas")
conn = conectar()
df = pd.read_sql_query("SELECT id, modalidade, valor, cronograma FROM grade_horarios", conn)
conn.close()

if not df.empty:
    df['valor'] = df['valor'].map('R$ {:,.2f}'.format)
    st.dataframe(df, use_container_width=True)
else:
    st.info("Nenhuma modalidade encontrada.")
